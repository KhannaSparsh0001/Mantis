# Required — Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SECRET_API_KEY=your_service_role_key

# Required — MOSS (semantic search)
MOSS_PROJECT_ID=your_moss_project_id
MOSS_PROJECT_KEY=your_moss_project_key

# Required — OpenCode (AI diagnostics)
OPENCODE_API_KEY=your_opencode_api_key

# Optional — API defaults
PORT=8000
FRONTEND_URL=http://localhost:3000
OPENCODE_BASE_URL=https://opencode.ai/zen/v1
OPENCODE_MODEL=mimo-v2.5-free

# Optional — auto-assign roles on login (email:role, comma-separated)
AUTH_EMAIL_WHITELIST=admin@mantis.demo:admin,company@mantis.demo:user

# Optional — restrict email signups
# AUTH_EMAIL_WHITELIST=admin@example.com:admin,staff@example.com:user
